# Backend
API_PORT=8787

# Temporary single-user login gate
APP_LOGIN_USERNAME=admin
APP_LOGIN_PASSWORD=replace_with_a_strong_password
# Optional: session lifetime in milliseconds. Default is 12 hours.
AUTH_SESSION_TTL_MS=43200000

# Market data
# auto allows fallback chaining for local development.
# alpaca and massive are strict modes and will not mix displayed prices across providers.
MARKET_DATA_PROVIDER=auto

# Alpaca market data
# Basic/free accounts can use feed=iex. Paid Algo Trader Plus can use feed=sip.
ALPACA_API_KEY_ID=your_alpaca_key_id_here
ALPACA_API_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_FEED=iex

# Alpaca paper trading API. This is for account/order endpoints, not market data.
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets/v2

# Massive is Polygon.io's rebranded API. api.massive.com is the new base;
# api.polygon.io is still supported by Massive during the transition.
MASSIVE_API_KEY=your_massive_api_key_here
MASSIVE_BASE_URL=https://api.massive.com
# Use delayed by default. Switch to wss://socket.massive.com/stocks when your plan has real-time access.
MASSIVE_WS_URL=wss://delayed.massive.com/stocks

# Backward-compatible aliases if you already have old local names.
POLYGON_API_KEY=your_polygon_or_massive_api_key_here

# AI analysis
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=your_ai_provider_key_here
AI_MODEL=deepseek-v4-flash

# Backward-compatible DeepSeek names still work.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
