generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model PortfolioHolding {
  id           String   @id @default(uuid())
  symbol       String
  shares       Float
  averageCost  Float
  conviction   String   @default("core")
  timeHorizon  String   @default("long-term")
  thesis       String   @default("")
  invalidation String   @default("")
  riskNotes    String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model JournalEntry {
  id        String   @id @default(uuid())
  timestamp String
  ticker    String
  side      String
  price     String
  duration  String
  rr        String
  tag       String
  pnl       String
  notes     String
  createdAt DateTime @default(now())
}

model AiMemory {
  id        String   @id @default(uuid())
  category  String
  content   String
  symbol    String   @default("GLOBAL")
  source    String   @default("user_pinned")
  pinned    Boolean  @default(false)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatInteraction {
  id        String   @id @default(uuid())
  symbol    String
  prompt    String
  response  String
  createdAt DateTime @default(now())
}

model ContextAttachment {
  id        String   @id @default(uuid())
  title     String
  content   String
  symbol    String   @default("GLOBAL")
  scope     String   @default("symbol")
  createdAt DateTime @default(now())
}

